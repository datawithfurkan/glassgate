# glasgate.ai Backend Configuration

# Server
PORT=3001
NODE_ENV=development

# Auth (leave empty to disable API key protection)
GLASGATE_API_KEY=

# CORS — comma-separated allowed origins (dev defaults are added automatically)
ALLOWED_ORIGINS=

# Crawler
CRAWL_TIMEOUT=8000
MAX_PAGES=10
MAX_SITEMAP_URLS=100
MAX_LLMS_TXT_PAGES=8
BOT_USER_AGENT=GlassGateBot/0.1 (+https://glasgate.ai/bot)

# Cache
CACHE_TTL_MS=600000

# Storage — absolute or relative to project root
GENERATED_DIR=./generated

# Frontend (Vite)
# Leave empty in dev — Vite proxies /api and /generated to localhost:3001
VITE_API_URL=

